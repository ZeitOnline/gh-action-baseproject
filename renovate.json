{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  
    "dependencyDashboard": true,
  
    "schedule": ["every weekend"],
  
    "draftPR": true,
  
    "enabledManagers": [
      "github-actions"
      ],
  
      "packageRules": [
        {
          "matchUpdateTypes": ["minor", "patch"],
          "matchManagers": ["github-actions"],
          "semanticCommitType": "fix",
          "semanticCommitScope": "gha",
          "groupName": "github-actions",
          "automerge": true
        },
        {
          "description": "Use fix prefix for action.yml updates, so release-please recognizes them as patch updates",
          "matchFileNames": ["action.yml"],
          "matchManagers": ["github-actions"],
          "semanticCommitType": "fix",
          "semanticCommitScope": "gha"
        },
        {
          "description": "Label dependencies that are older than 6 months",
          "matchPackagePatterns": [
            "*"
          ],
          "matchCurrentAge": "> 6 months",
          "addLabels": [
            "older-than-6-months"
          ]
        }
      ]
}
